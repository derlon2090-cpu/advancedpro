{
  "name": "advancedpro-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "build": "npm run prisma:generate",
    "model:smoke": "node src/scripts/modelSmokeTest.js",
    "render:build": "npm run build && node -e \"if (process.env.REQUIRE_MODEL_SMOKE_TEST === 'true') { require('child_process').execSync('npm run model:smoke', { stdio: 'inherit' }); } else { console.log('Skipping model smoke test. Set REQUIRE_MODEL_SMOKE_TEST=true to block deploys without approved models.'); }\"",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.19.0"
  }
}
