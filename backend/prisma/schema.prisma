generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  fullName       String
  email          String           @unique
  passwordHash   String
  role           String           @default("user")
  status         String           @default("active")
  resetCodeHash  String?
  resetCodeExpiresAt DateTime?
  resetCodeRequestedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  subscriptions  Subscription[]
  codeRedemptions CodeRedemption[]
  generations    Generation[]
  usageLogs      UsageLog[]
}

model Plan {
  id                       Int      @id @default(autoincrement())
  name                     String
  imageQuota               Int
  videoQuota               Int
  videoMaxDurationSeconds  Int
  validityDays             Int
  price                    Float?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Code {
  id                      Int      @id @default(autoincrement())
  code                    String   @unique
  planName                String
  imageQuota              Int      @default(0)
  videoQuota              Int      @default(0)
  videoMaxDurationSeconds Int      @default(60)
  validityDays            Int      @default(30)
  renewalEnabled          Boolean  @default(false)
  renewalEveryDays        Int?
  renewalMode             String   @default("topup")
  renewalImageQuota       Int      @default(0)
  renewalVideoQuota       Int      @default(0)
  maxRedemptions          Int      @default(1)
  redeemedCount           Int      @default(0)
  isActive                Boolean  @default(true)
  assignedEmail           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  redemptions             CodeRedemption[]
  subscriptions           Subscription[]
}

model CodeRedemption {
  id         Int      @id @default(autoincrement())
  userId     Int
  codeId     Int
  redeemedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  code       Code     @relation(fields: [codeId], references: [id])
}

model Subscription {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  codeId                  Int?
  packageName             String
  imageBalance            Int      @default(0)
  videoBalance            Int      @default(0)
  videoMaxDurationSeconds Int      @default(60)
  startAt                 DateTime
  endAt                   DateTime
  renewalEnabled          Boolean  @default(false)
  renewalEveryDays        Int?
  renewalMode             String   @default("topup")
  renewalImageQuota       Int      @default(0)
  renewalVideoQuota       Int      @default(0)
  status                  String   @default("active")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id])
  code                    Code?    @relation(fields: [codeId], references: [id])
  usageLogs               UsageLog[]
}

model UsageLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  subscriptionId Int
  type           String
  amountUsed     Int      @default(1)
  promptText     String?
  outputUrl      String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
}

model Generation {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  prompt    String
  status    String   @default("queued")
  resultUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String?
}
