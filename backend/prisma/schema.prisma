generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  fullName       String
  email          String           @unique
  passwordHash   String
  role           String           @default("user")
  status         String           @default("active")
  resetCodeHash  String?
  resetCodeExpiresAt DateTime?
  resetCodeRequestedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  subscriptions  Subscription[]
  codeRedemptions CodeRedemption[]
  generations    Generation[]
  usageLogs      UsageLog[]
}

model Plan {
  id                       Int      @id @default(autoincrement())
  name                     String
  description              String?
  imageQuota               Int
  videoQuota               Int
  videoMaxDurationSeconds  Int
  validityDays             Int
  price                    Float?
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Code {
  id                      Int      @id @default(autoincrement())
  code                    String   @unique
  planName                String
  imageQuota              Int      @default(0)
  videoQuota              Int      @default(0)
  videoMaxDurationSeconds Int      @default(60)
  validityDays            Int      @default(30)
  renewalEnabled          Boolean  @default(false)
  renewalEveryDays        Int?
  renewalMode             String   @default("topup")
  renewalImageQuota       Int      @default(0)
  renewalVideoQuota       Int      @default(0)
  maxRedemptions          Int      @default(1)
  redeemedCount           Int      @default(0)
  isActive                Boolean  @default(true)
  assignedEmail           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  redemptions             CodeRedemption[]
  subscriptions           Subscription[]
}

model CodeRedemption {
  id         Int      @id @default(autoincrement())
  userId     Int
  codeId     Int
  redeemedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  code       Code     @relation(fields: [codeId], references: [id])
}

model Subscription {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  codeId                  Int?
  packageName             String
  imageBalance            Int      @default(0)
  videoBalance            Int      @default(0)
  videoMaxDurationSeconds Int      @default(60)
  startAt                 DateTime
  endAt                   DateTime
  renewalEnabled          Boolean  @default(false)
  renewalEveryDays        Int?
  renewalMode             String   @default("topup")
  renewalImageQuota       Int      @default(0)
  renewalVideoQuota       Int      @default(0)
  status                  String   @default("active")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id])
  code                    Code?    @relation(fields: [codeId], references: [id])
  usageLogs               UsageLog[]
}

model UsageLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  subscriptionId Int
  type           String
  amountUsed     Int      @default(1)
  promptText     String?
  outputUrl      String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
}

model Generation {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  prompt    String
  status    String   @default("queued")
  resultUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String?
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  userType    String?  @map("user_type")
  action      String
  module      String
  description String?
  status      String   @default("success")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  browser     String?
  os          String?
  route       String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model GenerationJob {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  keyId        Int?     @map("key_id")
  type         String
  prompt       String
  quality      String?
  duration     Int?
  model        String?
  creditsUsed  Int      @default(0) @map("credits_used")
  status       String   @default("queued")
  resultUrl    String?  @map("result_url")
  provider     String?
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  @@map("generations")
}

model CreditTransaction {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  keyId        Int?     @map("key_id")
  amount       Int
  type         String
  reason       String
  generationId Int?     @unique @map("generation_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("credit_transactions")
}

model ActivationCode {
  id                Int       @id @default(autoincrement())
  code              String    @unique
  balance           Int       @default(0)
  email             String?
  ownerName         String?   @map("owner_name")
  imageLimit        Int       @default(0) @map("image_limit")
  videoLimit        Int       @default(0) @map("video_limit")
  imageUsed         Int       @default(0) @map("image_used")
  videoUsed         Int       @default(0) @map("video_used")
  isActive          Boolean   @default(true) @map("is_active")
  isUsed            Boolean   @default(false) @map("is_used")
  isRenewable       Boolean   @default(false) @map("is_renewable")
  renewalType       String?   @map("renewal_type")
  expiresAt         DateTime? @map("expires_at")
  notes             String?
  activatedByUserId Int?      @map("activated_by_user_id")
  activatedAt       DateTime? @map("activated_at")
  startsAt          DateTime? @map("starts_at")
  lastRenewedAt     DateTime? @map("last_renewed_at")
  subscriptionId    Int?      @map("subscription_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("activation_codes")
}
